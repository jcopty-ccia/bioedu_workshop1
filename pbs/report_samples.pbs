#!/bin/bash
#PBS -P your_project_code
#PBS -q normal
#PBS -l walltime=00:01:00
#PBS -l ncpus=1
#PBS -l mem=1GB
#PBS -l jobfs=1GB
#PBS -l wd
#PBS -N sample_report

echo "Queued sample summary"
date
echo
echo "Samples with status COMPLETE:"
grep "COMPLETE" data/samples.tsv
echo
echo "Unique projects:"
awk 'NR > 1 {print $2}' data/samples.tsv | sort | uniq
